PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# Set to enable persistent SQLite storage (omit for in-memory dev mode)
# DATABASE_URL=file:./data/q.db

# ── Authentication ───────────────────────────────────────────────────────────
# JWT signing secret (change in production!)
# JWT_SECRET=your-secret-here

# ── LLM provider for the chat agent ──────────────────────────────────────────
# 'anthropic' (default) — Anthropic SDK, native tool-use
# 'gemini'              — Google Gemini via its OpenAI-compatible endpoint
# 'openai'              — any OpenAI-compatible endpoint (see examples below)
LLM_PROVIDER=anthropic

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6   # default; also accepts claude-opus-4-6, claude-haiku-4-5-20251001

# ── Google Gemini ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash       # default; also accepts gemini-1.5-pro, gemini-2.0-pro, etc.

# ── Generic OpenAI-compatible LLM ─────────────────────────────────────────────
# Works with: OpenAI, DeepSeek, Groq, Ollama, MiniMax, OpenRouter, and more.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=
# LLM_MODEL=gpt-4o

# Provider examples:
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1          LLM_MODEL=gpt-4o
#   DeepSeek:   LLM_BASE_URL=https://api.deepseek.com/v1        LLM_MODEL=deepseek-chat
#   Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1     LLM_MODEL=llama-3.3-70b-versatile
#   Ollama:     LLM_BASE_URL=http://localhost:11434/v1           LLM_MODEL=llama3.2   LLM_API_KEY=ollama
#   MiniMax:    LLM_BASE_URL=https://api.minimax.io/v1          LLM_MODEL=MiniMax-Text-01
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1       LLM_MODEL=anthropic/claude-3.5-sonnet

# ── Speech-to-text ────────────────────────────────────────────────────────────
# Defaults to LLM_BASE_URL so a single-provider setup needs no extra config.
# STT_BASE_URL=https://api.openai.com/v1
# STT_API_KEY=                    # defaults to LLM_API_KEY
# STT_MODEL=whisper-1
# STT_PATH=/audio/transcriptions  # MiniMax uses: /speech/recognitions

# ── Embeddings ────────────────────────────────────────────────────────────────
# 'openai' (default) | 'ollama' | 'minimax'
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# MiniMax (used for embedding provider 'minimax' only)
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=

# ── Vector store ──────────────────────────────────────────────────────────────
CHROMA_URL=http://localhost:8000
# Optional: use a pre-existing ChromaDB collection instead of Q's own namespace
# CHROMA_COLLECTION=my_existing_index
# MRL: truncate embeddings for cheaper storage. Must match what was used at ingest time.
# text-embedding-3-small supports 256-1536 | nomic-embed-text supports 64-768
# EMBEDDING_DIMENSIONS=256
